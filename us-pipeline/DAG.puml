@startuml US VC Syndication Networks Pipeline DAG

skinparam defaultTextAlignment center
skinparam componentStyle rectangle
skinparam padding 4
skinparam nodesep 40
skinparam ranksep 50

skinparam rectangle {
  RoundCorner 10
  FontSize 12
}

' Color legend
skinparam legend {
  BackgroundColor #FEFEFE
  BorderColor #CCCCCC
}

legend bottom right
  |= Layer |= Color |
  | Raw | <#E8F5E9> |
  | Staging | <#E3F2FD> |
  | Core | <#FFF3E0> |
  | Graph | <#F3E5F5> |
  | Experiment | <#FCE4EC> |
  | Report | <#FFFDE7> |
end legend

' Raw layer
rectangle "**raw.companies**" as raw_companies #E8F5E9
rectangle "**raw.investments**" as raw_investments #E8F5E9
rectangle "**raw.investors**" as raw_investors #E8F5E9
rectangle "**raw.funding_rounds**" as raw_funding_rounds #E8F5E9

' Staging layer
rectangle "**stg.companies_clean**" as stg_companies_clean #E3F2FD
rectangle "**stg.investments_clean**" as stg_investments_clean #E3F2FD
rectangle "**stg.investments_funded**" as stg_investments_funded #E3F2FD

' Core layer
rectangle "**core.vc_investments**" as core_vc_investments #FFF3E0
rectangle "**core.investment_pairs**" as core_investment_pairs #FFF3E0

' Graph layer
rectangle "**graph.nodes**" as graph_nodes #F3E5F5
rectangle "**graph.edges**" as graph_edges #F3E5F5

' Experiment layer
rectangle "**exp.johnson_nestedness**" as exp_johnson #FCE4EC

' Report layer
rectangle "**report.johnson_nestedness**" as report_johnson #FFFDE7

' Edges: Raw → Staging
raw_companies --> stg_companies_clean
raw_investments --> stg_investments_clean
raw_investors --> stg_investments_clean
raw_funding_rounds --> stg_investments_clean

' Edges: Staging → Staging
stg_companies_clean --> stg_investments_funded
stg_investments_clean --> stg_investments_funded

' Edges: Staging → Core
stg_investments_funded --> core_vc_investments

' Edges: Core → Core
core_vc_investments --> core_investment_pairs

' Edges: Core → Graph
core_investment_pairs --> graph_nodes
core_investment_pairs --> graph_edges

' Edges: Graph → Experiment
graph_nodes --> exp_johnson
graph_edges --> exp_johnson

' Edges: Experiment → Report
exp_johnson --> report_johnson

@enduml
